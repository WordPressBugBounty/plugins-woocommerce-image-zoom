msgstr ""

#: includes/admin/class-wc-gallery-admin.php
msgid "Remove the WooCommerce Product Gallery element."
msgstr ""

#: includes/admin/class-wc-gallery-admin.php
msgid "Add a <strong>Shortcode</strong> element with <code>[wpbean_product_gallery]</code>."
msgstr ""

#: includes/admin/class-wc-gallery-admin.php
msgid "Bricks Builder: Product Template Detected"
msgstr ""

#: includes/admin/class-wc-gallery-admin.php
msgid "<strong>Bricks Builder</strong> has a template assigned to single product pages. Bricks renders outside WooCommerce's standard hook system, preventing our gallery from loading automatically."
